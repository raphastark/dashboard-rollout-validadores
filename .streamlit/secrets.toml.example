# Copie este arquivo para secrets.toml e preencha com os valores do seu
# Service Account JSON do GCP. NUNCA comite o arquivo secrets.toml real.
#
# Como obter:
#  1. Console GCP -> IAM & Admin -> Service Accounts
#  2. Crie uma SA (ex: dashboard-rollout) com as roles:
#       - BigQuery Data Viewer
#       - BigQuery Job User
#  3. Em Keys -> Add Key -> JSON, baixe o arquivo
#  4. Copie cada campo do JSON para os campos abaixo
#  5. A private_key precisa manter os \n literais entre as linhas

[gcp_service_account]
type = "service_account"
project_id = "rj-smtr"
private_key_id = "COLE_AQUI"
private_key = "-----BEGIN PRIVATE KEY-----\nCOLE_A_CHAVE_INTEIRA_AQUI\n-----END PRIVATE KEY-----\n"
client_email = "dashboard-rollout@rj-smtr.iam.gserviceaccount.com"
client_id = "COLE_AQUI"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "COLE_AQUI"
universe_domain = "googleapis.com"

# Fonte da verdade da frota em tempo real. A API devolve, no instante da
# chamada, os validadores que estão atualmente instalados nos veículos
# (somente quem está transmitindo no momento). É usada para filtrar os
# resultados do BigQuery e descartar validadores que já foram removidos
# da frota mas ainda têm registros históricos.
[fleet_api]
url = "COLE_AQUI"
